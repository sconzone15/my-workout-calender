DTEND:20260303T190000
RRULE:FREQ=WEEKLY;BYDAY=TU,TH;UNTIL=20260427T235959Z
SUMMARY:Active Recovery
DESCRIPTION:Zone 2 Cardio (Brisk walk or light bike) + 10m Stretching. Keep heart rate low.
BEGIN:VALARM
TRIGGER:-PT15M
ACTION:DISPLAY
DESCRIPTION:Recovery is where growth happens.
END:VALARM
END:VEVENT

