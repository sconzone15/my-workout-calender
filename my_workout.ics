DTSTART:20260302T180000
DTEND:20260302T191500
RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR;UNTIL=20260427T235959Z
SUMMARY:Main Workout: Progression Day
DESCRIPTION:WARMUP: 10m Upright Bike (Elevated HR)\n\nSTRENGTH (3 Rounds):\n- Weeks 1-2: 20 Squats / 16 Steps / 10 Pushups\n- Weeks 3-4: 25 Squats / 20 Steps / 12 Pushups\n- Weeks 5-6: 30 Squats / 24 Steps / 15 Pushups\n- Weeks 7-8: 35 Squats / 30 Steps / 20 Pushups\n\nEMOM FINISHER (3 Rounds):\n- Min 1: Echo Bike (Wks 1-4: 8cal / Wks 5-8: 10cal)\n- Min 2: MAX RPM (Sprint)\n- Min 3: Relaxed Spin\n- Min 4: Rest
BEGIN:VALARM
TRIGGER:-PT15M
ACTION:DISPLAY
DESCRIPTION:Time to level up.
END:VALARM
END:VEVENT

BEGIN:VEVENT
UID:recovery_tue_thu
DTSTAMP:20260223T180000
